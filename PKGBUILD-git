pkgname=everydaylinuxusertools-git
pkgver=1.0.r0.gabcdef  # r0 + short git hash, automatically set later
pkgrel=1
pkgdesc="GTK application providing everyday Linux utilities (Bluetooth control) - git version"
arch=('any')
url="https://github.com/yourusername/everydaylinuxusertools"
license=('GPL3')
depends=('python' 'python-gobject' 'gtk3' 'polkit')
optdepends=('bluez: Bluetooth support')
makedepends=('git')

pkgver() {
    cd "$srcdir/everydaylinuxusertools"
    # Get number of commits and short hash
    local commits=$(git rev-list --count HEAD)
    local hash=$(git rev-parse --short HEAD)
    echo "1.0.r${commits}.g${hash}"
}

source=(
    "git+https://github.com/yourusername/everydaylinuxusertools.git"
)
sha256sums=('SKIP')

build() {
    # No build needed, just copy files
    return 0
}

package() {
    cd "$srcdir/everydaylinuxusertools"

    install -Dm755 src/everydaylinuxusertools.py \
        "$pkgdir/usr/bin/everydaylinuxusertools"

    install -Dm644 desktop/everydaylinuxusertools.desktop \
        "$pkgdir/usr/share/applications/everydaylinuxusertools.desktop"
}